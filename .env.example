# =============================================================
# Variables de entorno - TechCup Backend
# Copiar este archivo como .env y completar los valores
#   cp .env.example .env
# =============================================================

# --- Base de Datos ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=techcup_db

# --- JWT ---
JWT_SECRET=TechCupDosw2026SecretKeyForJwtTokensMustBeLongEnough123456

# --- SSL ---
SSL_KEY_STORE_PASSWORD=password

# --- Perfil Spring activo: local | azure ---
SPRING_PROFILES_ACTIVE=local

# --- Azure PostgreSQL Flexible Server (solo perfil azure) ---
# AZURE_DB_HOST=your-server.postgres.database.azure.com
# AZURE_DB_NAME=techcup_db
# AZURE_DB_USER=adminuser
# AZURE_DB_PASSWORD=your-azure-password
# ALLOWED_ORIGINS=https://your-frontend.azurewebsites.net
