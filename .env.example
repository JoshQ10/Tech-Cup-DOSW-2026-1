# =============================================================
# Variables de entorno - TechCup Backend
# Copiar este archivo como .env y completar los valores
#   cp .env.example .env
# NUNCA subir el archivo .env al repositorio
# =============================================================

# --- Perfil Spring activo: local | qa | prod | azure ---
SPRING_PROFILES_ACTIVE=azure

# --- Base de Datos (perfil local / Docker Compose) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=techcup_db

# --- JWT (usar un valor seguro en produccion, minimo 32 chars) ---
JWT_SECRET=TechCupDosw2026SecretKeyForJwtTokensMustBeLongEnough123456

# --- SSL ---
SSL_KEY_STORE_PASSWORD=password

# --- Correo electronico (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password-de-gmail

# --- Correo electronico (Resend API) ---
RESEND_ENABLED=false
RESEND_PREFER_API=true
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev
RESEND_FALLBACK_FROM=onboarding@resend.dev
RESEND_REPLY_TO=

# --- Azure PostgreSQL - perfil azure (generico) ---
# AZURE_DB_HOST=your-server.postgres.database.azure.com
# AZURE_DB_NAME=techcup_db
# AZURE_DB_USER=adminuser@your-server
# AZURE_DB_PASSWORD=your-azure-password
# ALLOWED_ORIGINS=https://your-frontend.azurewebsites.net

# --- Azure PostgreSQL - perfil QA (entorno de pruebas) ---
# QA_DB_HOST=techcup-qa.postgres.database.azure.com
# QA_DB_NAME=techcup_qa
# QA_DB_USER=adminuser@techcup-qa
# QA_DB_PASSWORD=your-qa-password
# QA_ALLOWED_ORIGINS=https://techcup-frontend-qa.azurewebsites.net

# --- Azure PostgreSQL - perfil PROD (produccion) ---
# PROD_DB_HOST=techcup-prod.postgres.database.azure.com
# PROD_DB_NAME=techcup_prod
# PROD_DB_USER=adminuser@techcup-prod
# PROD_DB_PASSWORD=your-prod-password
# PROD_ALLOWED_ORIGINS=https://techcup-frontend.azurewebsites.net

# ─────────────────────────────────────────────────────────
# GITHUB SECRETS requeridos para CI/CD (configurar en
# Settings > Secrets and variables > Actions del repo):
# ─────────────────────────────────────────────────────────
# Comunes:
#   JWT_SECRET, SSL_KEY_STORE_PASSWORD
#   MAIL_HOST, MAIL_PORT, MAIL_USERNAME, MAIL_PASSWORD
#   ACR_LOGIN_SERVER    -> ej: techcup.azurecr.io
#   ACR_USERNAME        -> nombre de usuario del ACR
#   ACR_PASSWORD        -> contrasena del ACR
#
# SonarQube (opcional):
#   SONAR_TOKEN         -> token de autenticacion
#   SONAR_HOST_URL      -> ej: http://sonar.tuservidor.com
#   SONAR_PROJECT_KEY   -> ej: tech-cup-dosw-2026
#
# QA:
#   AZURE_CREDENTIALS_QA       -> JSON del service principal
#   AZURE_APP_NAME_QA          -> nombre del App Service QA
#   AZURE_RESOURCE_GROUP_QA    -> resource group del App Service QA
#   QA_DB_HOST, QA_DB_NAME, QA_DB_USER, QA_DB_PASSWORD
#   QA_ALLOWED_ORIGINS
#
# PROD:
#   AZURE_CREDENTIALS_PROD     -> JSON del service principal
#   AZURE_APP_NAME_PROD        -> nombre del App Service PROD
#   AZURE_RESOURCE_GROUP_PROD  -> resource group del App Service PROD
#   PROD_DB_HOST, PROD_DB_NAME, PROD_DB_USER, PROD_DB_PASSWORD
#   PROD_ALLOWED_ORIGINS
# ─────────────────────────────────────────────────────────
